# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Full DSN for the Go API (pgx connection pool)
DATABASE_URL=postgres://govlens:password@localhost:5432/govlens?sslmode=disable

# Used by golang-migrate CLI (make migrate)
# Same as DATABASE_URL but with migrate:// prefix when using pgx driver
MIGRATE_DB=postgres://govlens:password@localhost:5432/govlens?sslmode=disable

# ── Redis ───────────────────────────────────────────────────────────────────
# Accepts redis:// URL or plain host:port
REDIS_URL=redis://localhost:6379

# ── NATS JetStream ──────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── JWT ─────────────────────────────────────────────────────────────────────
# Use a long random secret in production: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-a-long-random-string

# ── Go API ──────────────────────────────────────────────────────────────────
PORT=8000

# URL the Go API uses to reach the ML sidecar (inside docker: http://ml-sidecar:8001)
ML_SIDECAR_URL=http://localhost:8001

# ── ML Sidecar ──────────────────────────────────────────────────────────────
# asyncpg DSN (note: postgresql:// not postgres://)
POSTGRES_URL=postgresql://govlens:password@localhost:5432/govlens

# ── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api/v1
