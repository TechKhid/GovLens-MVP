# GovLens MVP frontend environment variables
# Copy this file to .env.local and fill in your values.

# Base URL the browser uses to call the API.
# Full-stack local (Docker Compose + Nginx on :80):
#   NEXT_PUBLIC_API_URL=http://localhost/api/v1
#
# Split local dev (Go API running directly on :8000, no Nginx):
#   NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
#
# Production:
#   NEXT_PUBLIC_API_URL=https://api.govlens.my/api/v1
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# Google Maps JavaScript API browser key.
# Restrict this key by HTTP referrer before using it outside local development.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Cloud Map ID used for vector maps and Advanced Markers.
NEXT_PUBLIC_GOOGLE_MAP_ID=
